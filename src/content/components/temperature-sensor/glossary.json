{
  "terms": [
    {
      "term": "Negative Temperature Coefficient Thermistor (NTC)",
      "definition": "Negative temperature coefficient (R falls with T)."
    },
    {
      "term": "Resistance Temperature Detector (RTD)",
      "definition": "Resistance temperature detector."
    },
    {
      "term": "Seebeck",
      "definition": "Voltage from temperature gradient."
    },
    {
      "term": "Self-heating",
      "definition": "Current warms the sensor."
    }
  ]
}
