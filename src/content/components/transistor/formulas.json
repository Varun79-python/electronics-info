          "symbol": "g_m",
          "name": "Transconductance",
          "unit": "S"
        },
        {
          "symbol": "V_T",
          "name": "Thermal voltage",
          "unit": "V"
        }
      ],
      "example": "At 1mA, g_m≈38mS"
