{
  "formulas": [
    {
      "name": "Current Gain",
      "formula": "I_C = β × I_B",
      "description": "Collector current from base current.",
      "variables": [
        {
          "symbol": "I_C",
          "name": "Collector current",
          "unit": "A"
        },
        {
          "symbol": "β",
          "name": "Gain",
