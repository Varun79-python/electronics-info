        },
        {
          "symbol": "I_B",
          "name": "Base current",
          "unit": "A"
        }
      ],
      "example": "β=100, I_B=1mA → I_C=100mA"
    },
    {
      "name": "Transconductance",
      "formula": "g_m = I_C / V_T",
